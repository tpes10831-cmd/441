-- ===================== 水上行走功能 =====================
local WaterWalkEnabled = false
local WaterBase = nil

-- 獲取水面物件
local function GetWaterBase()
    if WaterBase and WaterBase.Parent then
        return WaterBase
    end
    
    -- 嘗試找到水面物件
    local Map = workspace:FindFirstChild("Map")
    if Map then
        WaterBase = Map:FindFirstChild("WaterBase-Plane")
    end
    
    return WaterBase
end

-- 設置水上行走
local function SetWaterWalk(enabled)
    local waterBase = GetWaterBase()
    if not waterBase then
        -- 如果找不到水面，嘗試其他可能的路徑
        waterBase = workspace:FindFirstChild("WaterBase-Plane")
        if not waterBase then
            waterBase = workspace:FindFirstChild("Map") and workspace.Map:FindFirstChild("WaterBase")
        end
    end
    
    if waterBase and waterBase:IsA("BasePart") then
        if enabled then
            -- 提高水面高度，讓角色可以站在水面上
            waterBase.Size = Vector3.new(1000, 112, 1000)
            waterBase.CanCollide = true
            WaterWalkEnabled = true
            WindUI:Notify({ 
                Title = "水上行走", 
                Content = "已開啟 - 可以在水面上行走", 
                Duration = 3 
            })
        else
            -- 恢復原本的水面高度
            waterBase.Size = Vector3.new(1000, 80, 1000)
            WaterWalkEnabled = false
            WindUI:Notify({ 
                Title = "水上行走", 
                Content = "已關閉", 
                Duration = 2 
            })
        end
    else
        WindUI:Notify({ 
            Title = "錯誤", 
            Content = "找不到水面物件", 
            Duration = 3,
            Icon = "alert-triangle"
        })
    end
end

-- 定期檢查並維持水上行走狀態（防止遊戲重置）
local waterWalkLoop = nil
local function StartWaterWalkLoop()
    if waterWalkLoop then
        task.cancel(waterWalkLoop)
        waterWalkLoop = nil
    end
    
    waterWalkLoop = task.spawn(function()
        while WaterWalkEnabled do
            task.wait(2)
            pcall(function()
                if WaterWalkEnabled then
                    local waterBase = GetWaterBase()
                    if waterBase and waterBase:IsA("BasePart") then
                        -- 確保水面高度維持在112
                        if waterBase.Size.Y ~= 112 then
                            waterBase.Size = Vector3.new(1000, 112, 1000)
                        end
                    end
                end
            end)
        end
        waterWalkLoop = nil
    end)
end

