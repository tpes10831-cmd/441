-- 聚怪循環
local simpleBringMobLoop = nil
local function StartSimpleBringMob()
    if simpleBringMobLoop then
        task.cancel(simpleBringMobLoop)
        simpleBringMobLoop = nil
    end
    
    simpleBringMobLoop = task.spawn(function()
        while SimpleBringMob.Enabled do
            task.wait(0.1)  -- 每0.1秒執行一次
            
            pcall(function()
                local MyCharacter = game.Players.LocalPlayer.Character
                if not MyCharacter then return end
                
                local MyRoot = MyCharacter:FindFirstChild("HumanoidRootPart")
                if not MyRoot then return end
                
                -- 計算玩家前方2單位位置
                local lookVector = MyRoot.CFrame.LookVector
                local targetPos = MyRoot.Position + (lookVector * 2)  -- 固定2單位
                local targetCFrame = CFrame.new(targetPos)
                
                -- 查找所有怪物（包含Boss）
                local Enemies = workspace:FindFirstChild("Enemies")
                if not Enemies then return end
                
                for i, v in pairs(Enemies:GetChildren()) do
                    local hrp = v:FindFirstChild("HumanoidRootPart")
                    if hrp then
                        local distance = (hrp.Position - MyRoot.Position).Magnitude
                        
                        -- 只要距離小於設定值就拉過來
                        if distance <= SimpleBringMob.Distance then
                            hrp.CFrame = targetCFrame
                            -- 不縮小怪物，保持原大小
                        end
                    end
                end
            end)
        end
        simpleBringMobLoop = nil
    end)
end

