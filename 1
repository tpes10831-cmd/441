-- 初始化所有玩家的狀態
local playerHealthStates = {}

-- 重置特定玩家的狀態
local function resetPlayerHealthState(player)
    if player then
        playerHealthStates[player.UserId] = {
            state = "NORMAL",
            lastLowTime = 0,
            teleportTriggered = false
        }
    end
end

-- 獲取玩家當前狀態
local function getPlayerHealthState(player)
    if not playerHealthStates[player.UserId] then
        resetPlayerHealthState(player)
    end
    return playerHealthStates[player.UserId]
end

-- 更新玩家血量狀態（無冷卻版本）
local function updatePlayerHealthState(player, currentHealthPercent)
    local stateData = getPlayerHealthState(player)
    local currentTime = tick()
    
    if currentHealthPercent <= HealthDetectConfig.HealthThreshold then
        -- 低血量狀態
        if stateData.state == "NORMAL" then
            stateData.lastLowTime = currentTime
            stateData.state = "LOW"
            stateData.teleportTriggered = false
        elseif stateData.state == "LOW" then
            if not stateData.teleportTriggered and (currentTime - stateData.lastLowTime) > 0.5 then
                stateData.teleportTriggered = true
                return "TRIGGER_TELEPORT"
            end
        end
    else
        -- 血量恢復正常 - 直接回到正常狀態
        if stateData.state == "LOW" then
            stateData.state = "NORMAL"
            stateData.teleportTriggered = false
        end
    end
    
    return "NO_ACTION"
end

