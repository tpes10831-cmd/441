    if locationData.type == "remote" then
        pcall(function()
            ReplicatedStorage.Remotes.CommF_:InvokeServer(locationData.remote)
            success = true
        end)
    elseif locationData.type == "cframe" then
        hrp.CFrame = locationData.CFrame
        success = true
    elseif locationData.type == "custom" then
        hrp.CFrame = CFrame.new(CustomX, CustomY, CustomZ)
        success = true
    end
    
    if success then
        HealthDetectConfig.LastTeleportTime = tick()
        
        if HealthDetectConfig.ShowNotifications then
            WindUI:Notify({
                Title = "⚠️ 血量危急 ⚠️",
