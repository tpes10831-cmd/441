-- 修改設置跳躍的函數
local function setJumpEnabled(enabled)
    jumpEnabled = enabled
    
    if enabled then
        -- 檢測平台類型
        local isMobile = UserInputService.TouchEnabled and not UserInputService.MouseEnabled
        
        if isMobile then
            -- 手機/平板：使用觸控檢測
            setupMobileJumpDetection()
            -- 顯示跳躍按鈕
            if not mobileJumpGui or not mobileJumpGui.Parent then
                createMobileJumpButton()
            else
                mobileJumpGui.Enabled = true
            end
            WindUI:Notify({ 
                Title = "跳躍修改", 
                Content = "手機模式已開啟，使用跳躍按鈕", 
                Duration = 3 
            })
        else
            -- PC：使用鍵盤檢測
            setupKeyboardJumpDetection()
            WindUI:Notify({ 
                Title = "跳躍修改", 
                Content = "PC模式已開啟，按住空格跳躍", 
                Duration = 2 
            })
        end
        
        startJumpLoop()
        updateJumpButtonHeight()
    else
        -- 關閉功能時清理所有連線
        if jumpConnection then
            jumpConnection:Disconnect()
            jumpConnection = nil
        end
        if jumpInputBegan then
            jumpInputBegan:Disconnect()
            jumpInputBegan = nil
        end
        if jumpInputEnded then
            jumpInputEnded:Disconnect()
            jumpInputEnded = nil
        end
        if touchBeganConnection then
            touchBeganConnection:Disconnect()
            touchBeganConnection = nil
        end
        if touchEndedConnection then
            touchEndedConnection:Disconnect()
            touchEndedConnection = nil
        end
        
        jumpHold = false
        touchJumpActive = false
        
        -- 隱藏手機按鈕
        if mobileJumpGui then
            mobileJumpGui.Enabled = false
        end
        
        -- 重置角色狀態
        local char = LocalPlayer.Character
        if char then
            local humanoid = char:FindFirstChildOfClass("Humanoid")
            if humanoid then
                humanoid.Jump = false
            end
        end
        
        WindUI:Notify({ 
            Title = "跳躍修改", 
            Content = "已關閉", 
            Duration = 2 
        })
    end
end

