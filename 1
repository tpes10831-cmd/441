-- 命令系統
local function updateChatCommands()
    game:GetService("Players").LocalPlayer.Chatted:Connect(function(msg)
        msg = msg:lower()
        
        if msg == "/esp on" then
            enableESPPro()
       elseif msg == "/esp off" then
            disableESPPro()
        elseif msg == "/attack on" then
            AttackConfig.Enabled = true
            startAttackLoop()
            WindUI:Notify({ Title = "快速攻擊", Content = "已開啟", Duration = 2 })
        elseif msg == "/attack off" then
            AttackConfig.Enabled = false
            if attackConnection then
                attackConnection:Disconnect()
                attackConnection = nil
            end
            WindUI:Notify({ Title = "快速攻擊", Content = "已關閉", Duration = 2 })
        elseif msg == "/attack status" then
            print("快速攻擊系統狀態:")
            print("啟用: " .. (AttackConfig.Enabled and "是" or "否"))
            print("攻擊範圍: " .. AttackConfig.AttackDistance)
            print("攻擊速度: " .. AttackConfig.AttackDelay .. "秒")
            print("攻擊怪物: " .. (AttackConfig.AttackMobs and "是" or "否"))
            print("攻擊玩家: " .. (AttackConfig.AttackPlayers and "是" or "否"))
        elseif msg == "/rotation on" then
            ROTATION_CONFIG.Enabled = true
            startRotation()
        elseif msg == "/rotation off" then
            ROTATION_CONFIG.Enabled = false
            stopRotation()
        elseif msg == "/jump on" then
            setJumpEnabled(true)
        elseif msg == "/jump off" then
            setJumpEnabled(false)
        elseif msg == "/hp on" then
            HealthDetectConfig.Enabled = true
            resetAllHealthStates()
            startHealthDetection()
            WindUI:Notify({ Title = "血量偵測（智能模式）", Content = "已開啟（無冷卻）", Duration = 2 })
        elseif msg == "/hp off" then
            HealthDetectConfig.Enabled = false
            resetAllHealthStates()
            WindUI:Notify({ Title = "血量偵測", Content = "已關閉", Duration = 2 })
        elseif msg == "/bring on" then
            SimpleBringMob.Enabled = true
            StartSimpleBringMob()
            WindUI:Notify({ Title = "聚怪功能", Content = "已開啟", Duration = 2 })
        elseif msg == "/bring off" then
            SimpleBringMob.Enabled = false
            StopSimpleBringMob()
            WindUI:Notify({ Title = "聚怪功能", Content = "已關閉", Duration = 2 })
        elseif msg == "/water on" then
            SetWaterWalk(true)
            StartWaterWalkLoop()
            WindUI:Notify({ Title = "水上行走", Content = "已開啟", Duration = 2 })
        elseif msg == "/water off" then
            SetWaterWalk(false)
            if waterWalkLoop then
                task.cancel(waterWalkLoop)
                waterWalkLoop = nil
            end
            WindUI:Notify({ Title = "水上行走", Content = "已關閉", Duration = 2 })
        end
    end)
end

updateChatCommands()

