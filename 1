function UniversalAttack.new()
    local self = setmetatable({
        Debounce = 0,
        ComboDebounce = 0,
        ShootDebounce = 0,
        M1Combo = 0,
        EnemyRootPart = nil,
        LastAttackTime = 0,
        LastScanTime = 0,
        CachedTargets = {},
        AttackConnection = nil
    }, UniversalAttack)
    
    return self
end

function UniversalAttack:IsTargetAlive(target)
    local humanoid = target and target:FindFirstChild("Humanoid")
    return humanoid and humanoid.Health > 0
end

function UniversalAttack:GetAllTargets(character)
    local currentTime = tick()
    if currentTime - self.LastScanTime < 0.3 and #self.CachedTargets > 0 then
        return self.CachedTargets
    end
    
    local targets = {}
    local characterPos = character and character:GetPivot().Position
    
    if not characterPos then
        self.CachedTargets = targets
        return targets
    end
    
    if AttackConfig.AttackMobs then
        local enemies = Workspace:FindFirstChild("Enemies")
        if enemies then
            for _, enemy in ipairs(enemies:GetChildren()) do
                if enemy ~= character and self:IsTargetAlive(enemy) then
                    local rootPart = enemy:FindFirstChild("HumanoidRootPart")
                    if rootPart and (characterPos - rootPart.Position).Magnitude <= AttackConfig.AttackDistance then
                        if not self.EnemyRootPart then
                            self.EnemyRootPart = rootPart
                        end
                        table.insert(targets, {enemy, rootPart})
                    end
                end
            end
        end
    end
    
    if AttackConfig.AttackPlayers then
        for _, player in ipairs(Players:GetPlayers()) do
            if player ~= LocalPlayer then
                local targetChar = player.Character
                if targetChar and self:IsTargetAlive(targetChar) then
                    local rootPart = targetChar:FindFirstChild("HumanoidRootPart")
                    if rootPart and (characterPos - rootPart.Position).Magnitude <= AttackConfig.AttackDistance then
                        if not self.EnemyRootPart then
                            self.EnemyRootPart = rootPart
                        end
                        table.insert(targets, {targetChar, rootPart})
                    end
                end
            end
        end
    end
    
    self.LastScanTime = currentTime
    self.CachedTargets = targets
    return targets
end

function UniversalAttack:GetCombo()
    local currentTime = tick()
    local combo = (currentTime - self.ComboDebounce) <= AttackConfig.ComboResetTime and self.M1Combo or 0
    combo = combo >= AttackConfig.MaxCombo and 1 or combo + 1
    self.ComboDebounce = currentTime
    self.M1Combo = combo
    return combo
end

function UniversalAttack:HandleFruitAttack(character, equipped, combo)
    local targets = self:GetAllTargets(character)
    if not targets[1] then return end
    
    local fruitRemote = equipped:FindFirstChild("LeftClickRemote")
    if fruitRemote then
        local direction = (targets[1][2].Position - character:GetPivot().Position).Unit
        fruitRemote:FireServer(direction, combo)
    end
end

function UniversalAttack:HandleMeleeAttack(character)
    self.EnemyRootPart = nil
    local targets = self:GetAllTargets(character)
    
    if self.EnemyRootPart then
        RegisterAttack:FireServer(AttackConfig.AttackDelay)
        RegisterHit:FireServer(self.EnemyRootPart, targets)
    end
end

function UniversalAttack:Attack()
    if not AttackConfig.Enabled then return end
    
    local currentTime = tick()
    if (currentTime - self.Debounce) < AttackConfig.AttackDelay then return end
    
    local character = LocalPlayer.Character
    if not character or not character:FindFirstChild("Humanoid") then return end
    
    local equipped = character:FindFirstChildOfClass("Tool")
    if not equipped then return end
    
    local combo = self:GetCombo()
    self.Debounce = combo >= AttackConfig.MaxCombo and (currentTime + 0.05) or currentTime
    
    local toolTip = equipped.ToolTip
    if toolTip == "Blox Fruit" then
        self:HandleFruitAttack(character, equipped, combo)
    elseif toolTip == "Sword" or toolTip == "Melee" then
        self:HandleMeleeAttack(character)
    else
        self:HandleMeleeAttack(character)
    end
    
    self.LastAttackTime = currentTime
end

local attackSystem = UniversalAttack.new()
local attackConnection = nil

local function startAttackLoop()
    if attackConnection then
        attackConnection:Disconnect()
        attackConnection = nil
    end
    
    attackSystem = UniversalAttack.new()
    
    attackConnection = RunService.Heartbeat:Connect(function()
        if AttackConfig.Enabled then
            pcall(function()
                attackSystem:Attack()
            end)
        end
    end)
end

startAttackLoop()

LocalPlayer.CharacterAdded:Connect(function(character)
    task.wait(2)
    if AttackConfig.Enabled then
        startAttackLoop()
    end
end)

LocalPlayer.CharacterRemoving:Connect(function()
    if attackConnection then
        attackConnection:Disconnect()
        attackConnection = nil
    end
end)

local function ReconnectRemotes()
    Modules = ReplicatedStorage:WaitForChild("Modules")
    Net = Modules:WaitForChild("Net")
    RegisterAttack = Net:WaitForChild("RE/RegisterAttack")
    RegisterHit = Net:WaitForChild("RE/RegisterHit")
end

local function OnCharacterRespawn()
    ReconnectRemotes()
    
    if AttackConfig.Enabled then
        task.wait(1)
        startAttackLoop()
    end
end

LocalPlayer.CharacterAdded:Connect(function(character)
    task.wait(2)
    OnCharacterRespawn()
end)

