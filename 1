    if simpleBringMobLoop then
        task.cancel(simpleBringMobLoop)
        simpleBringMobLoop = nil
    end
    WindUI:Notify({ 
        Title = "聚怪功能", 
        Content = "已關閉", 
        Duration = 2 
    })
end

-- 免控旋轉功能
local ROTATION_CONFIG = {
    Enabled = false,
    RotationSpeed = 2000,
}

local rotationActive = false
local rotationConnection = nil
local moveKeys = {W=false, A=false, S=false, D=false}
local jumpHoldRot = false
local currentYaw = 0
local rotationInputBegan = nil
local rotationInputEnded = nil

local function setupRotationInput()
    if rotationInputBegan then
        rotationInputBegan:Disconnect()
        rotationInputBegan = nil
    end
    if rotationInputEnded then
        rotationInputEnded:Disconnect()
        rotationInputEnded = nil
    end
    
    rotationInputBegan = UserInputService.InputBegan:Connect(function(input, gameProcessed)
        if gameProcessed then return end
        if not ROTATION_CONFIG.Enabled then return end
        
        if input.KeyCode == Enum.KeyCode.W then moveKeys.W = true end
        if input.KeyCode == Enum.KeyCode.A then moveKeys.A = true end
        if input.KeyCode == Enum.KeyCode.S then moveKeys.S = true end
        if input.KeyCode == Enum.KeyCode.D then moveKeys.D = true end
        if input.KeyCode == Enum.KeyCode.Space then jumpHoldRot = true end
    end)

    rotationInputEnded = UserInputService.InputEnded:Connect(function(input, gameProcessed)
        if input.KeyCode == Enum.KeyCode.W then moveKeys.W = false end
        if input.KeyCode == Enum.KeyCode.A then moveKeys.A = false end
        if input.KeyCode == Enum.KeyCode.S then moveKeys.S = false end
        if input.KeyCode == Enum.KeyCode.D then moveKeys.D = false end
        if input.KeyCode == Enum.KeyCode.Space then jumpHoldRot = false end
    end)
end

local function startRotation()
    if rotationActive then return end
    
    local character = LocalPlayer.Character
    if not character then 
        WindUI:Notify({ Title = "免控旋轉", Content = "找不到角色", Duration = 2 })
        return 
    end
    
    local root = character:FindFirstChild("HumanoidRootPart")
    local humanoid = character:FindFirstChildOfClass("Humanoid")
    
    if not root or not humanoid then 
        WindUI:Notify({ Title = "免控旋轉", Content = "角色組件不完整", Duration = 2 })
        return 
    end
    
    humanoid.AutoRotate = false
    rotationActive = true
    currentYaw = root.Orientation.Y
    setupRotationInput()
    
    rotationConnection = RunService.Heartbeat:Connect(function(dt)
        if not ROTATION_CONFIG.Enabled or not rotationActive then return end
        
        local char = LocalPlayer.Character
        if not char then return end
        
        local rootPart = char:FindFirstChild("HumanoidRootPart")
        local hum = char:FindFirstChildOfClass("Humanoid")
        
        if not rootPart or not hum then return end
        if hum.Health <= 0 then return end
        
        currentYaw = currentYaw + ROTATION_CONFIG.RotationSpeed * dt
        
        local camCFrame = Workspace.CurrentCamera.CFrame
        local camLook = Vector3.new(camCFrame.LookVector.X, 0, camCFrame.LookVector.Z)
        local camRight = Vector3.new(camCFrame.RightVector.X, 0, camCFrame.RightVector.Z)
        
        local direction = Vector3.new(0, 0, 0)
        if moveKeys.W then direction = direction + camLook end
        if moveKeys.S then direction = direction - camLook end
        if moveKeys.A then direction = direction - camRight end
        if moveKeys.D then direction = direction + camRight end
        
        if direction.Magnitude > 0 then
            hum:Move(direction.Unit, false)
        else
            hum:Move(Vector3.new(0,0,0), false)
        end
        
        if jumpHoldRot and hum:GetState() ~= Enum.HumanoidStateType.Jumping then
            hum.Jump = true
        else
            hum.Jump = false
        end
        
        rootPart.CFrame = CFrame.new(rootPart.Position) * CFrame.Angles(0, math.rad(currentYaw), 0)
    end)
    
    WindUI:Notify({ 
        Title = "免控旋轉", 
        Content = "免控功能已開啟", 
        Duration = 3 
    })
end

local function stopRotation()
    rotationActive = false
    ROTATION_CONFIG.Enabled = false
    
    if rotationConnection then
        rotationConnection:Disconnect()
        rotationConnection = nil
    end
    
    local char = LocalPlayer.Character
    if char then
        local humanoid = char:FindFirstChildOfClass("Humanoid")
        if humanoid then
            humanoid.AutoRotate = true
            humanoid.Jump = false
        end
    end
    
    moveKeys = {W=false, A=false, S=false, D=false}
    jumpHoldRot = false
    
    WindUI:Notify({ Title = "免控旋轉", Content = "免控功能已關閉", Duration = 2 })
end

