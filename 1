local function startHealthDetection()
    task.spawn(function()
        while HealthDetectConfig.Enabled do
            task.wait(HealthDetectConfig.CheckInterval)
            
            local character = LocalPlayer.Character
            if not character then continue end
            
            local humanoid = character:FindFirstChildOfClass("Humanoid")
            if not humanoid or humanoid.Health <= 0 then continue end
            
            local healthPercent = (humanoid.Health / humanoid.MaxHealth) * 100
            
            if HealthDetectConfig.OnlyInCombat then
                local inCombat = false
                if not inCombat then continue end
            end
            
            local action = updatePlayerHealthState(LocalPlayer, healthPercent)
            
            if action == "TRIGGER_TELEPORT" then
                performHealthTeleport()
            end
        end
    end)
end

