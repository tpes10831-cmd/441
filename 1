-- ================= 手機兼容的跳躍高度修改器（範圍10-1000）=================
local JUMP_HEIGHT = 100
local jumpEnabled = false
local jumpHold = false
local jumpConnection = nil
local jumpInputBegan = nil
local jumpInputEnded = nil

-- 手機跳躍檢測變量
local touchJumpActive = false
local touchBeganConnection = nil
local touchEndedConnection = nil

-- 手機跳躍按鈕
local mobileJumpButton = nil
local mobileJumpGui = nil

local function setupMobileJumpDetection()
    -- 清除舊的連線
    if touchBeganConnection then
        touchBeganConnection:Disconnect()
        touchBeganConnection = nil
    end
    if touchEndedConnection then
        touchEndedConnection:Disconnect()
        touchEndedConnection = nil
    end
    
    -- 檢測觸控開始
    touchBeganConnection = UserInputService.TouchStarted:Connect(function(touch, gameProcessed)
        if gameProcessed or not jumpEnabled then return end
        
        -- 檢測是否在跳躍按鈕區域（螢幕右下半部，跳躍按鈕通常在那裡）
        local screenSize = Camera.ViewportSize
        local touchPos = touch.Position
        
        -- 跳躍按鈕通常在螢幕右下角
        if touchPos.X > screenSize.X * 0.7 and touchPos.Y > screenSize.Y * 0.6 then
            touchJumpActive = true
            jumpHold = true
        end
    end)
    
    -- 檢測觸控結束
    touchEndedConnection = UserInputService.TouchEnded:Connect(function(touch, gameProcessed)
        if gameProcessed then return end
        
        -- 檢查是否還有其他活躍的觸控
        local touches = UserInputService:GetTouches()
        local stillJumping = false
        
        for _, activeTouch in ipairs(touches) do
            local touchPos = activeTouch.Position
            local screenSize = Camera.ViewportSize
            if touchPos.X > screenSize.X * 0.7 and touchPos.Y > screenSize.Y * 0.6 then
                stillJumping = true
                break
            end
        end
        
        if not stillJumping then
            touchJumpActive = false
            jumpHold = false
        end
    end)
    
    -- 同時保留鍵盤支持
    setupKeyboardJumpDetection()
end

local function setupKeyboardJumpDetection()
    -- 清除舊的鍵盤連線
    if jumpInputBegan then
        jumpInputBegan:Disconnect()
        jumpInputBegan = nil
    end
    if jumpInputEnded then
        jumpInputEnded:Disconnect()
        jumpInputEnded = nil
    end
    
    -- 鍵盤按下
    jumpInputBegan = UserInputService.InputBegan:Connect(function(input, gpe)
        if gpe or not jumpEnabled then return end
        if input.KeyCode == Enum.KeyCode.Space then
            jumpHold = true
        end
        -- 也支持遊戲手柄的A鍵
        if input.KeyCode == Enum.KeyCode.ButtonA then
            jumpHold = true
        end
    end)

    -- 鍵盤釋放
    jumpInputEnded = UserInputService.InputEnded:Connect(function(input, gpe)
        if input.KeyCode == Enum.KeyCode.Space then
            jumpHold = false
        end
        if input.KeyCode == Enum.KeyCode.ButtonA then
            jumpHold = false
        end
    end)
end

-- 修改跳躍循環，讓它更平滑
local function startJumpLoop()
    if jumpConnection then
        jumpConnection:Disconnect()
        jumpConnection = nil
    end
    
    jumpConnection = RunService.Heartbeat:Connect(function(dt)
        if jumpEnabled and jumpHold then
            local char = LocalPlayer.Character
            if char then
                local root = char:FindFirstChild("HumanoidRootPart")
                local humanoid = char:FindFirstChildOfClass("Humanoid")
                if root and humanoid and humanoid.Health > 0 then
                    -- 更平滑的跳躍
                    if root.Velocity.Y < JUMP_HEIGHT then
                        local force = JUMP_HEIGHT * 2
                        root.Velocity = Vector3.new(root.Velocity.X, math.min(root.Velocity.Y + force * dt, JUMP_HEIGHT), root.Velocity.Z)
                    end
                    
                    -- 確保角色處於跳躍狀態
                    if humanoid:GetState() ~= Enum.HumanoidStateType.Jumping and 
                       humanoid:GetState() ~= Enum.HumanoidStateType.Freefall then
                        humanoid.Jump = true
                    end
                end
            end
        else
            -- 當不跳躍時，重置角色的跳躍狀態
            local char = LocalPlayer.Character
            if char then
                local humanoid = char:FindFirstChildOfClass("Humanoid")
                if humanoid then
                    humanoid.Jump = false
                end
            end
        end
    end)
end

