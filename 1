-- 追蹤傳送循環 - 使用 CFrame 實現平滑移動，不受任何物理影響
local function TrackPlayer(target)
    -- 開啟穿牆
    EnableNoClip()
    
    while TrackConfig.Enabled and target and target.Parent do
        task.wait(0.03)
        
        local character = LocalPlayer.Character
        if not character then break end
        
        local hrp = character:FindFirstChild("HumanoidRootPart")
        local targetChar = target.Character
        if not targetChar then break end
        
        local targetRoot = targetChar:FindFirstChild("HumanoidRootPart")
        if not hrp or not targetRoot then break end
        
        -- 計算目標位置加上XYZ偏離
        local targetPos = targetRoot.Position
        local offsetPos = Vector3.new(
            targetPos.X + TrackConfig.OffsetX,
            targetPos.Y + TrackConfig.OffsetY,
            targetPos.Z + TrackConfig.OffsetZ
        )
        
        -- 計算當前位置到目標位置的距離
        local currentPos = hrp.Position
        local distance = (offsetPos - currentPos).Magnitude
        
        -- 如果距離很近，直接設定位置
        if distance < 1 then
            hrp.CFrame = CFrame.new(offsetPos)
        else
            -- 計算移動方向和距離
            local direction = (offsetPos - currentPos).Unit
            
            -- 根據速度計算每次移動的距離
            local moveDistance = TrackConfig.Speed * 0.03  -- 0.03是task.wait的時間
            
            -- 如果移動距離大於實際距離，直接設定位置
            if moveDistance >= distance then
                hrp.CFrame = CFrame.new(offsetPos)
            else
                -- 否則移動一部分距離
                local newPos = currentPos + direction * moveDistance
                hrp.CFrame = CFrame.new(newPos)
            end
        end
        
        -- 重置所有物理影響
        hrp.Velocity = Vector3.zero
        hrp.RotVelocity = Vector3.zero
        hrp.AssemblyLinearVelocity = Vector3.zero
        hrp.AssemblyAngularVelocity = Vector3.zero
        
        -- 確保 Humanoid 不會干擾
        local humanoid = character:FindFirstChildOfClass("Humanoid")
        if humanoid then
            humanoid.PlatformStand = true
            humanoid.AutoRotate = false
        end
        
        -- 面向目標
        local lookDir = (Vector3.new(targetPos.X, 0, targetPos.Z) - Vector3.new(hrp.Position.X, 0, hrp.Position.Z)).Unit
        if lookDir.Magnitude > 0.1 then
            hrp.CFrame = CFrame.lookAt(hrp.Position, hrp.Position + lookDir)
        end
    end
    
    -- 關閉穿牆
    DisableNoClip()
    
    -- 恢復 Humanoid 設定
    local character = LocalPlayer.Character
    if character then
        local humanoid = character:FindFirstChildOfClass("Humanoid")
        if humanoid then
            humanoid.PlatformStand = false
            humanoid.AutoRotate = true
        end
        
        local hrp = character:FindFirstChild("HumanoidRootPart")
        if hrp then
            hrp.Velocity = Vector3.zero
            hrp.RotVelocity = Vector3.zero
            hrp.AssemblyLinearVelocity = Vector3.zero
            hrp.AssemblyAngularVelocity = Vector3.zero
        end
    end
    
    TrackConfig.Enabled = false
    TrackConfig.TrackThread = nil
    TrackConfig.Target = nil
    
    -- 更新按鈕文字
    if trackButton then
        trackButton:SetTitle("開啟追蹤傳送")
    end
end

